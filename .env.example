# --- SGLang (gpt-oss-120b, GPU box) ---
# Pin a release tag for reproducibility (e.g. v0.5.12); "latest" also works.
SGLANG_TAG=latest
SGLANG_MODEL=openai/gpt-oss-120b
# Tensor parallelism: 1 for a single 80GB card (H100/H200), 4 for 4x smaller GPUs.
SGLANG_TP=1
SGLANG_PORT=30000

# --- llama.cpp (gpt-oss-20b, Mac / no-GPU host) ---
LLAMA_PORT=8080
# 0 = model's full trained context (131072). Lower it to save memory.
LLAMA_CTX=0

# --- Agent ---
# Host directory mounted at /workspace inside the agent container.
WORKSPACE=.
